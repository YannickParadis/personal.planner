@inherits LayoutComponentBase
@implements IDisposable
@inject ThemeState ThemeState
@inject IJSRuntime JS

<MudThemeProvider Theme="@CurrentTheme" IsDarkMode="ThemeState.IsDarkMode" ObserveSystemThemeChange="false" />
<MudPopoverProvider />

<div class="layout-shell">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main>
        <div class="top-row px-4">
            <span class="top-brand-wordmark">personal.planner</span>
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="top-row-actions">
                <MudBadge Dot="true" Color="Color.Success" Overlap="true">
                    <MudAvatar Variant="Variant.Outlined" Color="Color.Info" Size="Size.Medium">
                        <MudIcon Icon="@Icons.Material.Filled.Person" />
                    </MudAvatar>
                </MudBadge>
            </MudStack>
        </div>

        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">X</span>
</div>

@code {
    private const string ThemePreferenceKey = "personal.planner.theme.mode";
    private const string LegacyThemePreferenceKey = "personal.planner.theme.darkmode";
    private MudTheme CurrentTheme => ThemeState.Mode == ThemeMode.DarkSlate ? AppTheme.SlateTheme : AppTheme.BlueTheme;

    protected override void OnInitialized()
    {
        ThemeState.Changed += HandleThemeChanged;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        var savedValue = await JS.InvokeAsync<string?>("localStorage.getItem", ThemePreferenceKey);
        if (int.TryParse(savedValue, out var savedMode) &&
            Enum.IsDefined(typeof(ThemeMode), savedMode))
        {
            ThemeState.Mode = (ThemeMode)savedMode;
            return;
        }

        var legacyValue = await JS.InvokeAsync<string?>("localStorage.getItem", LegacyThemePreferenceKey);
        if (bool.TryParse(legacyValue, out var legacyDarkMode))
        {
            ThemeState.Mode = legacyDarkMode ? ThemeMode.DarkBlue : ThemeMode.Light;
            await JS.InvokeVoidAsync("localStorage.setItem", ThemePreferenceKey, ((int)ThemeState.Mode).ToString());
        }
    }

    private void HandleThemeChanged()
    {
        _ = InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        ThemeState.Changed -= HandleThemeChanged;
    }
}
