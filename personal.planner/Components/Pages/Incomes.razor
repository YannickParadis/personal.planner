@page "/incomes"
@inject IncomeStore IncomeStore

<PageTitle>Income List</PageTitle>

<MudStack Spacing="3">
    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
        <div>
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                <MudIcon Icon="@Icons.Material.Filled.AttachMoney" Color="Color.Primary" />
                <MudText Typo="Typo.h4" GutterBottom="false">Income List</MudText>
            </MudStack>
            <MudText Typo="Typo.body2" Color="Color.Secondary">Track and manage your income entries.</MudText>
        </div>
        <MudChip T="string" Color="Color.Primary" Variant="Variant.Outlined" Icon="@Icons.Material.Filled.ReceiptLong" Label="true">
            @($"{IncomeStore.Incomes.Count} records")
        </MudChip>
    </MudStack>

    <MudPaper Class="pa-4">
        <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
            <MudStack Spacing="0">
                <MudText Typo="Typo.h6">Income Records</MudText>
                <MudText Typo="Typo.caption" Color="Color.Secondary">
                    Gross Total: @IncomeStore.Incomes.Sum(x => x.Amount).ToString("C2")
                </MudText>
            </MudStack>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="StartAdd" StartIcon="@Icons.Material.Filled.Add">
                Add Income
            </MudButton>
        </MudStack>
    </MudPaper>

    <MudPaper Class="pa-4">
        <MudDataGrid T="IncomeRow"
                     Items="IncomeStore.Incomes"
                     RowClick="OnGridRowClick"
                     Filterable="true"
                     SortMode="SortMode.Multiple"
                     RowsPerPage="20"
                     Dense="true"
                     Hover="true"
                     Striped="true">
            <Columns>
                <PropertyColumn Property="x => x.Amount" Title="Gross Amount ($)" Sortable="true" Filterable="true" Format="C2" />
                <PropertyColumn Property="x => x.TaxAmount" Title="Tax Amount ($)" Sortable="true" Filterable="true" Format="C2" />
                <TemplateColumn Title="Net Income ($)" Sortable="false" Filterable="false">
                    <CellTemplate>
                        @((context.Item.Amount - context.Item.TaxAmount).ToString("C2"))
                    </CellTemplate>
                </TemplateColumn>
                <PropertyColumn Property="x => x.Type" Title="Income Type" Sortable="true" Filterable="true" />
                <PropertyColumn Property="x => x.Date" Title="Received Date" Sortable="true" Filterable="true" Format="yyyy-MM-dd" />
                <TemplateColumn Title="Status" Sortable="false" Filterable="false">
                    <CellTemplate>
                        <MudChip T="string"
                                 Color="Color.Default"
                                 Variant="Variant.Filled"
                                 Size="Size.Small"
                                 Style="@GetStatusChipStyle(context.Item.Date)"
                                 Label="true">
                            @(IsDone(context.Item.Date) ? "Done" : "Open")
                        </MudChip>
                    </CellTemplate>
                </TemplateColumn>
                <TemplateColumn Title="Actions" Sortable="false" Filterable="false">
                    <CellTemplate>
                        <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                       Color="Color.Primary"
                                       Size="Size.Small"
                                       OnClick="@(() => StartEdit(context.Item))" />
                        <MudIconButton Icon="@Icons.Material.Filled.ContentCopy"
                                       Color="Color.Secondary"
                                       Size="Size.Small"
                                       OnClick="@(() => StartCopy(context.Item))" />
                        <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                       Color="Color.Error"
                                       Size="Size.Small"
                                       OnClick="@(() => DeleteIncome(context.Item.Id))" />
                    </CellTemplate>
                </TemplateColumn>
            </Columns>
            <PagerContent>
                <MudDataGridPager T="IncomeRow" PageSizeOptions="new int[] { 20 }" />
            </PagerContent>
        </MudDataGrid>
    </MudPaper>
</MudStack>

@if (_isFormPopupOpen)
{
    <div style="position: fixed; inset: 0; background-color: rgba(0, 0, 0, 0.45); z-index: 1200; display: flex; align-items: center; justify-content: center; padding: 16px;">
        <MudPaper Class="pa-4" Elevation="8" Style="width: min(640px, 100%);">
            <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-3">
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                    <MudIcon Icon="@(_isCopyMode ? Icons.Material.Filled.ContentCopy : (_editingIncomeId is null ? Icons.Material.Filled.AddCircle : Icons.Material.Filled.Edit))" Size="Size.Small" />
                    <MudText Typo="Typo.h6">@(_isCopyMode ? "Copy Income" : (_editingIncomeId is null ? "Add Income" : "Edit Income"))</MudText>
                </MudStack>
                <MudIconButton Icon="@Icons.Material.Filled.Close" OnClick="ResetForm" />
            </MudStack>

            <MudGrid>
                <MudItem xs="12" md="6">
                    <MudNumericField T="decimal"
                                     Label="Amount $"
                                     Variant="Variant.Outlined"
                                     @bind-Value="_formAmount"
                                     Min="0"
                                     Immediate="true" />
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudNumericField T="decimal"
                                     Label="Tax Amount $"
                                     Variant="Variant.Outlined"
                                     @bind-Value="_formTaxAmount"
                                     Min="0"
                                     Immediate="true" />
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudTextField Label="Type"
                                  Variant="Variant.Outlined"
                                  @bind-Value="_formType"
                                  Immediate="true" />
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudDatePicker Label="Date"
                                   Variant="Variant.Outlined"
                                   @bind-Date="_formDate"
                                   Editable="true" />
                </MudItem>
                <MudItem xs="12">
                    <MudStack Row="true" Spacing="2" Justify="Justify.FlexEnd">
                        <MudButton Variant="Variant.Outlined" Color="Color.Default" OnClick="ResetForm" StartIcon="@Icons.Material.Filled.Close">
                            Cancel
                        </MudButton>
                        <MudButton Variant="Variant.Filled" Color="Color.Success" OnClick="SaveIncome" StartIcon="@Icons.Material.Filled.Save">
                            Save
                        </MudButton>
                    </MudStack>
                </MudItem>
            </MudGrid>
        </MudPaper>
    </div>
}

@code {
    private int? _editingIncomeId;
    private bool _isCopyMode;
    private bool _isFormPopupOpen;
    private decimal _formAmount;
    private decimal _formTaxAmount;
    private string _formType = string.Empty;
    private DateTime? _formDate = DateTime.Today;

    private void StartAdd()
    {
        _editingIncomeId = null;
        _isCopyMode = false;
        _formAmount = 0;
        _formTaxAmount = 0;
        _formType = string.Empty;
        _formDate = DateTime.Today;
        _isFormPopupOpen = true;
    }

    private void StartEdit(IncomeRow income)
    {
        _editingIncomeId = income.Id;
        _isCopyMode = false;
        _formAmount = income.Amount;
        _formTaxAmount = income.TaxAmount;
        _formType = income.Type;
        _formDate = income.Date;
        _isFormPopupOpen = true;
    }

    private void StartCopy(IncomeRow income)
    {
        _editingIncomeId = null;
        _isCopyMode = true;
        _formAmount = income.Amount;
        _formTaxAmount = income.TaxAmount;
        _formType = income.Type;
        _formDate = income.Date;
        _isFormPopupOpen = true;
    }

    private void OnGridRowClick(DataGridRowClickEventArgs<IncomeRow> args)
    {
        if (args.MouseEventArgs.Detail == 2)
        {
            StartEdit(args.Item);
        }
    }

    private void SaveIncome()
    {
        if (string.IsNullOrWhiteSpace(_formType) || _formDate is null)
        {
            return;
        }

        if (_editingIncomeId is null)
        {
            IncomeStore.Add(_formAmount, _formTaxAmount, _formType, _formDate.Value);
        }
        else
        {
            IncomeStore.Update(_editingIncomeId.Value, _formAmount, _formTaxAmount, _formType, _formDate.Value);
        }

        ResetForm();
    }

    private void DeleteIncome(int incomeId)
    {
        IncomeStore.Delete(incomeId);

        if (_editingIncomeId == incomeId)
        {
            ResetForm();
        }
    }

    private void ResetForm()
    {
        _editingIncomeId = null;
        _isCopyMode = false;
        _formAmount = 0;
        _formTaxAmount = 0;
        _formType = string.Empty;
        _formDate = DateTime.Today;
        _isFormPopupOpen = false;
    }

    private static bool IsDone(DateTime incomeDate) => incomeDate.Date <= DateTime.Today;

    private static string GetStatusChipStyle(DateTime incomeDate) =>
        IsDone(incomeDate)
            ? "background-color:var(--sb-status-done-bg);color:var(--sb-status-text);"
            : "background-color:var(--sb-status-open-bg);color:var(--sb-status-text);";
}
